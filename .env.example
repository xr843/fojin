# ======================
# 本地开发配置（非 Docker）
# ======================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fojin
POSTGRES_USER=fojin
POSTGRES_PASSWORD=fojin_secret

# Elasticsearch
ES_HOST=http://localhost:9200

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT（生产环境请更换密钥）
JWT_SECRET_KEY=fojin-jwt-secret-change-in-production
JWT_EXPIRE_MINUTES=10080

# 端口映射（Docker 宿主机端口）
BACKEND_PORT=8000
FRONTEND_PORT=3000

# LLM (OpenAI-compatible)
LLM_API_KEY=sk-your-llm-api-key
LLM_API_URL=https://api.deepseek.com/v1

# Embedding
EMBEDDING_API_KEY=sk-your-embedding-api-key
EMBEDDING_API_URL=https://api.siliconflow.cn/v1

# Apify (爬虫)
APIFY_TOKEN=apify_api_your-token-here

# 典津 API (guji.cckb.cn)
DIANJIN_API_KEY=sk-gcis-your-api-key-here

# Dify AI 助手 (前端)
VITE_DIFY_APP_TOKEN=your-dify-token
VITE_DIFY_BASE_URL=http://localhost:8080
